---
import Layout from '../layouts/Layout.astro';
import ZipSearch from '../components/ZipSearch.jsx';
---

<Layout title="Page Not Found | Foundation Pricing">
  <div class="max-w-4xl mx-auto py-24 px-6 text-center">
    <div class="inline-flex items-center justify-center p-6 bg-orange-100 rounded-full mb-8">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
    </div>

    <h1 class="text-4xl sm:text-5xl font-black text-gray-900 tracking-tight mb-6">
      Whoops! Looks like this foundation settled a bit too much.
    </h1>
    
    <p class="text-xl text-gray-600 mb-12 max-w-2xl mx-auto">
      We can't find the page you're looking for, but we can still help you find local foundation repair costs and geotechnical soil data.
    </p>

    <div class="max-w-lg mx-auto bg-white p-8 rounded-2xl shadow-xl border border-gray-100 relative">
        <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 bg-blue-600 text-white px-4 py-1 rounded-full text-sm font-bold shadow-sm whitespace-nowrap">
            Get Back On Track
        </div>
        <h2 class="text-2xl font-bold text-gray-900 mb-6 mt-2">Enter your ZIP Code</h2>
        <ZipSearch client:load />
    </div>
    
    <div class="mt-16">
        <a href="/" class="text-blue-600 font-semibold hover:text-blue-800 transition-colors flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            Return to Homepage
        </a>
    </div>
  </div>
</Layout>
